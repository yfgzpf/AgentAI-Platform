{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentAI Platform",
  "version": "0.1.0-alpha.1",
  "identifier": "com.agentai.platform",
  "build": {
    "frontendDist": "../agentai-gui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @agentai/gui dev",
    "beforeBuildCommand": "pnpm --filter @agentai/gui build"
  },
  "app": {
    "windows": [
      {
        "title": "AgentAI Platform",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": "default-src 'self' ws: http://127.0.0.1:18789; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' ws: http://127.0.0.1:18789"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "完全免费的智能体框架平台",
    "longDescription": "AgentAI Platform — 极小桌面端 + 多模态 + 4 渠道 (Web/QQ/VSCode/Telegram)",
    "publisher": "AgentAI Builder",
    "copyright": "© 2026 AgentAI Builder"
  }
}
