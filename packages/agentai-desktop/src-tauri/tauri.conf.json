{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AgentAI Platform",
  "version": "0.1.0-alpha.1",
  "identifier": "com.agentai.desktop",
  "build": {
    "beforeDevCommand": "cd packages/agentai-gui && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd packages/agentai-gui && npm run build",
    "frontendDist": "../agentai-gui/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "AgentAI Platform",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.svg"
    ],
    "category": "DeveloperTool",
    "copyright": "AgentAI Platform",
    "license": "Apache-2.0"
  }
}
