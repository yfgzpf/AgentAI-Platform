{
  "name": "@agentai/gateway",
  "version": "0.1.0-alpha.1",
  "description": "AgentAI Gateway — Node.js 智能体网关 (Socket.io + 4 渠道适配器 + LLM 智能路由)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@agentai/core": "workspace:*",
    "socket.io": "^4.7.5",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "winston": "^3.13.0",
    "chokidar": "^3.6.0",
    "bull": "^4.12.2",
    "ioredis": "^5.4.1",
    "better-sqlite3": "^11.1.2",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "author": "AgentAI Builder",
  "license": "MIT"
}
